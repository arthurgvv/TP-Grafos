# Token do GitHub usado pelo comando fetch.
# Tambem e possivel usar GITHUB_AUTH_TOKENS com tokens separados por virgula.
GITHUB_TOKEN=
GITHUB_AUTH_TOKENS=

# Repositorio analisado.
GITHUB_REPO_OWNER=encode
GITHUB_REPO_NAME=httpx

# Amostra pequena para nao gastar muitas chamadas durante testes manuais.
MAX_ISSUES=20
MAX_PULLS=10
